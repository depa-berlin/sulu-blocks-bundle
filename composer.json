{
    "name": "depa/sulu-blocks-bundle",
    "description": "Meta-bundle that orchestrates modular Sulu block bundles with a registry, admin dashboard, and cross-bundle connections",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0",
        "depa/sulu-block-helper": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "twig/twig": "^3.0"
    },
    "suggest": {
        "depa/sulu-block-content": "Content block collection (text, image, button, etc.)",
        "depa/sulu-block-swiper": "Swiper/Carousel block collection"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/depa-berlin/sulu-block-helper"
        }
    ],
    "autoload": {
        "psr-4": {
            "Depa\\SuluBlocksBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluBlocksBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
