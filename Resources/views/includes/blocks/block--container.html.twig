{% set block_id = content._id|default %}
{% set display = content.display|default('full') %}
{% set displayType = '' %}
{% if display in ['full', 'full_row'] %}
    {% set displayType = 'full' %}
{% elseif display in ['boxed', 'boxed_row'] %}
    {% set displayType = 'boxed' %}
{% endif %}
{% set row = display in ['full_row', 'boxed_row'] %}

<div class="block--container {{ displayType }} {{ content.attr_class|default }}"
     {% if content.attr_id|default %}id="{{ content.attr_id }}"{% endif %} data-cms-block-id="{{ block_id }}" {{ sulu_block_preview(content) }}>
    {% if row %}<div class="row">{% endif %}
        {% if content.blocks|default([]) %}
            {% for block in content.blocks %}
                {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                    content: block,
                    view: view.blocks[loop.index0],
                } %}
            {% endfor %}
        {% endif %}
        {% if row %}</div>{% endif %}
</div>
